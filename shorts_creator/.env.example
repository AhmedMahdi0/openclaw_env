# AI Video Shorts Creator - Configuration
# Copy this file to .env and fill in your API keys

# RunwayML API (https://runwayml.com)
RUNWAYML_API_KEY=your_runwayml_api_key_here

# Pika Labs API (https://pika.art)
PIKA_API_KEY=your_pika_api_key_here

# OpenAI API for text generation (optional)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs for text-to-speech (optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Video configuration
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920  # Vertical for Shorts
VIDEO_FPS=30
VIDEO_DURATION_PER_IMAGE=3  # seconds per image

# Output directories
INPUT_IMAGES_DIR=./input_images
ENHANCED_IMAGES_DIR=./enhanced_images
GENERATED_VIDEOS_DIR=./generated_videos
FINAL_VIDEOS_DIR=./final_videos
AUDIO_DIR=./audio